# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# App URL (used in emails and Stripe redirects)
NEXT_PUBLIC_APP_URL=https://zerodamage.de

# Resend (Email)
RESEND_API_KEY=re_your-resend-key-here

# Cron Job Security (generate a random secret, e.g. openssl rand -hex 32)
CRON_SECRET=your-cron-secret-here

# Stripe
STRIPE_SECRET_KEY=sk_live_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Stripe Price IDs (create in Stripe Dashboard → Products)
# Regular prices (per unit/month)
STRIPE_PRICE_MONTHLY=price_monthly_regular
STRIPE_PRICE_YEARLY=price_yearly_regular
# Founder prices (50% discount, Year 1)
STRIPE_PRICE_FOUNDER_MONTHLY=price_monthly_founder
STRIPE_PRICE_FOUNDER_YEARLY=price_yearly_founder
# One-time setup fee
STRIPE_PRICE_SETUP_FEE=price_setup_fee_founder
